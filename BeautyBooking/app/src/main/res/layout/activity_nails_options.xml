<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/background_primary">
    <com.google.android.material.appbar.MaterialToolbar android:id="@+id/toolbar"
        android:layout_width="match_parent" android:layout_height="?attr/actionBarSize"
        app:navigationIcon="@drawable/ic_arrow_back" />
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="28dp">
            <FrameLayout android:layout_width="64dp" android:layout_height="64dp"
                android:background="@drawable/bg_icon_circle" android:layout_gravity="center" android:layout_marginBottom="20dp">
                <ImageView android:layout_width="32dp" android:layout_height="32dp"
                    android:layout_gravity="center" android:src="@drawable/ic_service_nails" android:importantForAccessibility="no" />
            </FrameLayout>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/nail_area" android:textSize="17sp" android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium" android:layout_marginBottom="12dp" android:letterSpacing="0.01" />
            <RadioGroup android:id="@+id/rgNailArea" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="28dp">
                <RadioButton android:id="@+id/rbHands" android:layout_width="match_parent" android:layout_height="50dp"
                    android:text="@string/nails_hands" android:textSize="15sp" />
                <RadioButton android:id="@+id/rbFeet" android:layout_width="match_parent" android:layout_height="50dp"
                    android:text="@string/nails_feet" android:textSize="15sp" />
            </RadioGroup>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/nail_type" android:textSize="17sp" android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium" android:layout_marginBottom="12dp" android:letterSpacing="0.01" />
            <RadioGroup android:id="@+id/rgNailType" android:layout_width="match_parent" android:layout_height="wrap_content">
                <RadioButton android:id="@+id/rbAcrygel" android:layout_width="match_parent" android:layout_height="50dp"
                    android:text="@string/nails_acrygel" android:textSize="15sp" />
                <RadioButton android:id="@+id/rbBasicColor" android:layout_width="match_parent" android:layout_height="50dp"
                    android:text="@string/nails_basic_color" android:textSize="15sp" />
                <RadioButton android:id="@+id/rbCleaning" android:layout_width="match_parent" android:layout_height="50dp"
                    android:text="@string/nails_cleaning" android:textSize="15sp" />
            </RadioGroup>
        </LinearLayout>
    </ScrollView>
    <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="20dp">
        <com.google.android.material.button.MaterialButton android:id="@+id/btnNext"
            style="@style/PrimaryButton" android:layout_width="match_parent" android:layout_height="56dp"
            android:text="@string/btn_continue" android:enabled="false" />
    </FrameLayout>
</LinearLayout>
