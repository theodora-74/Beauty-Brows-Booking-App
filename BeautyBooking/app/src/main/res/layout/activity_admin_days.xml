<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/background_primary">
    <com.google.android.material.appbar.MaterialToolbar android:id="@+id/toolbar"
        android:layout_width="match_parent" android:layout_height="?attr/actionBarSize"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:title="@string/manage_working_days" app:titleTextColor="@color/text_primary"
        app:titleTextAppearance="@style/ToolbarTitle" />
    <com.google.android.material.tabs.TabLayout android:id="@+id/tabLocation"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/background_primary" app:tabMode="fixed" app:tabGravity="fill"
        app:tabIndicatorColor="@color/dusty_rose" app:tabIndicatorHeight="2dp"
        app:tabSelectedTextColor="@color/dusty_rose_dark" app:tabTextColor="@color/text_hint"
        app:tabRippleColor="#10D4A0A0">
        <com.google.android.material.tabs.TabItem android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/location_thessaloniki" />
        <com.google.android.material.tabs.TabItem android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/location_litochoro" />
    </com.google.android.material.tabs.TabLayout>
    <com.google.android.material.button.MaterialButton android:id="@+id/btnRecurring"
        style="@style/Widget.Material3.Button.TonalButton" android:layout_width="wrap_content" android:layout_height="40dp"
        android:layout_gravity="center" android:layout_marginVertical="10dp"
        android:text="@string/recurring_schedule" android:textSize="13sp" app:cornerRadius="20dp" />
    <TextView android:id="@+id/tvHint" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="@string/tap_days_to_toggle" android:textSize="13sp" android:textColor="@color/text_hint"
        android:gravity="center" android:paddingBottom="10dp" />
    <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp" app:cardBackgroundColor="@color/surface_card"
        app:cardCornerRadius="20dp" app:cardElevation="0dp" app:strokeWidth="1dp" app:strokeColor="#08000000">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="center_vertical" android:layout_marginBottom="12dp">
                <com.google.android.material.button.MaterialButton android:id="@+id/btnPrevMonth"
                    style="@style/Widget.Material3.Button.IconButton" android:layout_width="44dp" android:layout_height="44dp"
                    android:text="‹" android:textSize="22sp" android:textColor="@color/text_secondary" />
                <TextView android:id="@+id/tvMonth" android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:textSize="16sp" android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-medium" android:gravity="center" />
                <com.google.android.material.button.MaterialButton android:id="@+id/btnNextMonth"
                    style="@style/Widget.Material3.Button.IconButton" android:layout_width="44dp" android:layout_height="44dp"
                    android:text="›" android:textSize="22sp" android:textColor="@color/text_secondary" />
            </LinearLayout>
            <LinearLayout android:id="@+id/llDayHeaders" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp" />
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvCalendar"
                android:layout_width="match_parent" android:layout_height="wrap_content" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
    <TextView android:id="@+id/tvSelectedCount" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textSize="15sp" android:textColor="@color/dusty_rose_dark" android:fontFamily="sans-serif-medium"
        android:gravity="center" android:padding="18dp" />
</LinearLayout>
