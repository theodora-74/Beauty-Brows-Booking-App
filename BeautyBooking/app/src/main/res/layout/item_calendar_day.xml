<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="48dp"
    android:orientation="vertical" android:gravity="center">
    <TextView android:id="@+id/tvDayNumber" android:layout_width="36dp" android:layout_height="36dp"
        android:textSize="14sp" android:textColor="@color/text_primary" android:gravity="center" />
    <View android:id="@+id/dotIndicator" android:layout_width="6dp" android:layout_height="6dp"
        android:background="@drawable/bg_calendar_dot" android:visibility="invisible" />
</LinearLayout>
