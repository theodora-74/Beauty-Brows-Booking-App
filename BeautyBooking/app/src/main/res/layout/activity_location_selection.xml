<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/background_primary">
    <com.google.android.material.appbar.MaterialToolbar android:id="@+id/toolbar"
        android:layout_width="match_parent" android:layout_height="?attr/actionBarSize"
        app:navigationIcon="@drawable/ic_arrow_back" />
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="@string/select_location" android:textSize="24sp"
        android:textColor="@color/text_primary" android:fontFamily="sans-serif-light"
        android:letterSpacing="0.02"
        android:paddingHorizontal="28dp" android:paddingTop="4dp" android:paddingBottom="28dp" />
    <com.google.android.material.card.MaterialCardView android:id="@+id/cardThessaloniki"
        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
        android:layout_marginHorizontal="28dp" android:layout_marginBottom="16dp"
        android:clickable="true" android:focusable="true"
        app:cardCornerRadius="24dp" app:cardElevation="0dp"
        app:cardBackgroundColor="@color/surface_card" app:strokeWidth="1dp" app:strokeColor="#08000000">
        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
            android:orientation="vertical" android:gravity="center" android:padding="28dp">
            <FrameLayout android:layout_width="64dp" android:layout_height="64dp"
                android:background="@drawable/bg_icon_circle" android:layout_marginBottom="16dp">
                <ImageView android:layout_width="32dp" android:layout_height="32dp"
                    android:layout_gravity="center" android:src="@drawable/ic_location_city"
                    android:importantForAccessibility="no" />
            </FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/location_thessaloniki" android:textSize="20sp"
                android:textColor="@color/text_primary" android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.02" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
    <com.google.android.material.card.MaterialCardView android:id="@+id/cardLitochoro"
        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
        android:layout_marginHorizontal="28dp" android:layout_marginBottom="40dp"
        android:clickable="true" android:focusable="true"
        app:cardCornerRadius="24dp" app:cardElevation="0dp"
        app:cardBackgroundColor="@color/surface_card" app:strokeWidth="1dp" app:strokeColor="#08000000">
        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
            android:orientation="vertical" android:gravity="center" android:padding="28dp">
            <FrameLayout android:layout_width="64dp" android:layout_height="64dp"
                android:background="@drawable/bg_icon_circle" android:layout_marginBottom="16dp">
                <ImageView android:layout_width="32dp" android:layout_height="32dp"
                    android:layout_gravity="center" android:src="@drawable/ic_location_mountain"
                    android:importantForAccessibility="no" />
            </FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/location_litochoro" android:textSize="20sp"
                android:textColor="@color/text_primary" android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.02" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
